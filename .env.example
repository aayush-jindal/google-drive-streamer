# ── Frontend (baked into JS bundle at build time) ────────────────────────────
# Password shown on the lock screen before accessing the app.
VITE_APP_PASSWORD=your-secret-password

# ── Serverless API routes (server-side only, never sent to browser) ───────────
# Full contents of your Google Service Account JSON key, minified to one line.
# Get it from: Google Cloud Console → IAM → Service Accounts → Keys → Add Key
# Paste the entire JSON on a single line (no line breaks).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Local development ──────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# Run `vercel dev` (not `npm run dev`) so the /api routes are served locally.
# NEVER commit .env.local — it contains your private key!
