# ── Required: Google Service Account Credentials ─────────────────────────────
# Full contents of your Google Service Account JSON key file.
# Get this from: Google Cloud Console → IAM & Admin → Service Accounts → Keys → Add Key → JSON
# Paste the entire JSON on a single line (no line breaks). You can minify with:
#   cat your-service-account.json | tr -d '\n' | pbcopy
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Required: App Password ──────────────────────────────────────────────────
# Password shown on the lock screen. Share this with family members who will use the app.
# Note: This is baked into the JS bundle at build time — use a unique password, not one used elsewhere.
VITE_APP_PASSWORD=your-secret-password-here

# ── Local Development ───────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# Run `vercel dev` (not `npm run dev`) so the /api routes are served locally.
# NEVER commit .env.local — it contains your private key!
