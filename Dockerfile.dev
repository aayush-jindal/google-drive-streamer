FROM node:20-alpine

WORKDIR /app

# Install deps inside the image (node_modules lives in the container)
COPY package*.json ./
RUN npm install

# Source is mounted at runtime via docker-compose volume
EXPOSE 5173

# Start the local API server (port 3001) and the Vite dev server (port 5173)
CMD ["sh", "-c", "node dev-server.js & npm run dev"]
